# Ansible inventory — 3× Lenovo IdeaPad tablets (Termux/Android)
# Targets are Termux sessions, not full Linux.
# Run from P14s WSL2 after ssh-copy-id is done (see HAL notes tablets).
#
# Usage:
#   ansible-playbook -i hosts site.yml
#   ansible -i hosts tablets -m ping    # connectivity check

[tablets]
tablet1 ansible_host=10.133.134.207 ansible_user=u0_a304
tablet2 ansible_host=10.133.134.219 ansible_user=u0_a360
tablet3 ansible_host=10.133.134.110 ansible_user=u0_a297

[tablets:vars]
ansible_port=8022
ansible_python_interpreter=/data/data/com.termux/files/usr/bin/python
ansible_become=false
# Termux has no sudo. All tasks run as the Termux user.
# Use proot-distro for root-requiring work inside the Arch container.

# Ansible inventory — 3× Lenovo IdeaPad tablets (Termux/Android)
# Targets are Termux sessions, not full Linux.
# Run from P14s WSL2 (Debian) after ssh-copy-id is done (see HAL notes tablets).
#
# Usage:
#   ansible-playbook -i hosts site.yml
#   ansible -i hosts tablets -m ping    # connectivity check

[tablets]
tablet1 ansible_host=10.197.86.207 ansible_user=u0_a304
tablet2 ansible_host=10.197.86.219 ansible_user=u0_a360
tablet3 ansible_host=10.197.86.110 ansible_user=u0_a297

[tablets:vars]
ansible_port=8022
ansible_python_interpreter=/data/data/com.termux/files/usr/bin/python
ansible_remote_tmp=/data/data/com.termux/files/usr/tmp/.ansible-tmp
ansible_become=false
# Termux has no sudo. All tasks run as the Termux user.
# Use proot-distro for root-requiring work inside the Debian container.

[wsl2]
p14s ansible_connection=local ansible_python_interpreter=/usr/bin/python3

[wsl2:vars]
ansible_become=false

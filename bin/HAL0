#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
# T.Dot lives inside ITI-Theory/ — sibling repos are one level up
ITI="$(cd -- "$REPO_ROOT/.." && pwd)"
ME_REPO="$(cd -- "$ITI/../Me" 2>/dev/null && pwd)" || ME_REPO="$HOME/prj/git/Me"

# ---------------------------------------------------------------------------
# Utilities
# ---------------------------------------------------------------------------

section() { echo ""; echo "--- $* ---"; }
banner()  { echo "================================================================"; echo "=== $*"; echo "================================================================"; }

# Load a module — fails loudly if file is missing (e.g. init never run)
_hal_source() {
  local mod="$SCRIPT_DIR/$1"
  if [[ ! -f "$mod" ]]; then
    echo "[HAL] ERROR: module '$1' not found at $mod" >&2
    echo "[HAL] Reinstall: cd T.Dot && bin/HAL0 init" >&2
    exit 1
  fi
  # shellcheck source=/dev/null
  source "$mod"
}

_hal_selftest() {
  # --quiet : silent on success; always loud on failure (stderr)
  local quiet=0
  [[ "${1:-}" == "--quiet" ]] && quiet=1
  local ok=1 failures=()

  for f in HAL HAL0; do
    [[ -x "$HOME/.local/bin/$f" ]] \
      || { failures+=("~/.local/bin/$f — missing, run: HAL0 init"); ok=0; }
  done
  for mod in "$SCRIPT_DIR"/HAL0-*; do
    [[ -f "$mod" ]] \
      || { failures+=("$(basename "$mod") not found — run: HAL0 init"); ok=0; }
  done
  command -v HAL &>/dev/null \
    || { failures+=("HAL not in PATH — add to ~/.bashrc: export PATH=\"\$HOME/.local/bin:\$PATH\""); ok=0; }

  if [[ $ok -eq 1 ]]; then
    if [[ $quiet -eq 0 ]]; then
      echo "=== HAL selftest ==="
      for f in HAL HAL0; do echo "  [ok] ~/.local/bin/$f"; done
      for mod in "$SCRIPT_DIR"/HAL0-*; do echo "  [ok] $(basename "$mod")"; done
      echo "  [ok] HAL in PATH ($(command -v HAL))"
      echo ""
      echo "  result: PASS"
    fi
  else
    echo "=== HAL selftest: FAIL ===" >&2
    for f in "${failures[@]}"; do echo "  [FAIL] $f" >&2; done
    echo "" >&2
    return 1
  fi
}

# ---------------------------------------------------------------------------
# HAL init — symlink HAL into PATH
# ---------------------------------------------------------------------------

do_init() {
  mkdir -p "$HOME/.local/bin"
  # Write a forwarding wrapper — not a symlink (Git Bash on Windows copies, not links).
  # The wrapper calls the real script so SCRIPT_DIR always resolves to the repo bin/.
  for script in HAL0 HAL; do
    local src="$SCRIPT_DIR/$script"
    local dst="$HOME/.local/bin/$script"
    rm -f "$dst"
    printf '#!/usr/bin/env bash\nexec "%s" "$@"\n' "$src" > "$dst"
    chmod +x "$dst" || true  # chmod fails on Windows DrvFS
  done
  echo "[HAL0] init complete — HAL0 and HAL dispatcher installed to ~/.local/bin"
  echo "[HAL0] Ensure ~/.local/bin is in PATH (add to ~/.bashrc if needed)"
  echo ""
  _hal_selftest
}

# ---------------------------------------------------------------------------
# HAL prime — base context block
# ---------------------------------------------------------------------------

do_prime() {
  banner "HAL prime — $(date '+%Y-%m-%d %H:%M')"

  section "MODE"
  echo "AUTOPILOT — propose actions as a numbered checklist, then wait."
  echo "User vocabulary: 'next'/'y' = next step; 'go all'/'A' = whole list;"
  echo "'stop'/'n' = abort. Full policy in master instructions below."

  section "MASTER INSTRUCTIONS (T/.github/copilot-instructions.md)"
  if [[ -f "$ITI/T/.github/copilot-instructions.md" ]]; then
    cat "$ITI/T/.github/copilot-instructions.md"
  else
    echo "[HAL] WARNING: T master instructions not found"
  fi

  section "U INSTRUCTIONS (U/.github/copilot-instructions.md)"
  if [[ -f "$ITI/U/.github/copilot-instructions.md" ]]; then
    cat "$ITI/U/.github/copilot-instructions.md"
  else
    echo "[HAL] WARNING: U instructions not found"
  fi

  section "FIELD-NOTES (last 40 lines)"
  if [[ -f "$ITI/U/paper/FIELD-NOTES.md" ]]; then
    tail -40 "$ITI/U/paper/FIELD-NOTES.md"
  else
    echo "[HAL] WARNING: FIELD-NOTES.md not found"
  fi

  section "GIT STATUS"
  for repo in U T.Ops Me; do
    local rpath
    if [[ "$repo" == "Me" ]]; then
      rpath="$ME_REPO"
    else
      rpath="$ITI/$repo"
    fi
    echo "=== $repo ==="
    if [[ -d "$rpath/.git" ]]; then
      git -C "$rpath" status -sb
    else
      echo "[not found at $rpath]"
    fi
  done
}

# ---------------------------------------------------------------------------
# Packs — loaded on top of base prime
# ---------------------------------------------------------------------------

pack_papers() {
  section "PACK: papers — U paper source files"
  local paper_dir="$ITI/U/paper"
  if [[ ! -d "$paper_dir" ]]; then
    echo "[HAL] WARNING: paper dir not found at $paper_dir"; return
  fi
  # Each paper lives in paper/soma/<name>/<name>.md (or ai-method/<name>/<name>.md)
  while IFS= read -r -d '' f; do
    echo ""
    echo "### FILE: $f ###"
    cat "$f"
  done < <(find "$paper_dir/soma" "$paper_dir/ai-method" -mindepth 2 -maxdepth 2 -name "*.md" -print0 2>/dev/null | sort -z)
}

pack_lean() {
  section "PACK: lean — U/paper/proofs Lean 4 source files"
  local src_dir="$ITI/U/paper/proofs"
  if [[ ! -d "$src_dir" ]]; then
    echo "[HAL] WARNING: proofs dir not found at $src_dir"; return
  fi
  while IFS= read -r -d '' f; do
    echo ""
    echo "### FILE: $f ###"
    cat "$f"
  done < <(find "$src_dir" -name "*.lean" -print0 | sort -z)
}

pack_process() {
  section "PACK: process — U/PROCESS.md"
  if [[ -f "$ITI/U/PROCESS.md" ]]; then
    cat "$ITI/U/PROCESS.md"
  else
    echo "[HAL] WARNING: PROCESS.md not found"
  fi
}

pack_issues() {
  section "PACK: issues — open GitHub issues (requires gh CLI)"
  if ! command -v gh &>/dev/null; then
    echo "[HAL] WARNING: gh CLI not found — install from https://cli.github.com"; return
  fi
  for repo in ITI-Theory/T.Ops ITI-Theory/U ITI-Theory/U.Ops; do
    echo ""
    echo "=== $repo ==="
    gh issue list --repo "$repo" --state open --limit 50 \
      --json number,title,labels,updatedAt \
      --template '{{range .}}#{{.number}} {{.title}} [{{range .labels}}{{.name}} {{end}}] ({{.updatedAt | timeago}}){{"\n"}}{{end}}' \
      2>/dev/null || echo "[no issues or access error]"
  done
}

# ---------------------------------------------------------------------------
# HAL notes — quick human-readable reference for a topic
# ---------------------------------------------------------------------------

do_notes() {
  local topic="${1:-}"
  case "$topic" in
    tablets)  pack_tablets ;;
    dotfiles) _notes_dotfiles ;;
    stack)    _notes_stack ;;
    *)
      echo "HAL notes <topic>"
      echo ""
      echo "Available topics:"
      echo "  tablets   — tablet IPs, bootstrap sequence, Termux:X11, Ansible, roles"
      echo "  dotfiles  — which dotfile repo is authoritative for which device"
      echo "  stack     — full device stack: what runs on P14s WSL2 vs tablets"
      ;;
  esac
}

_notes_dotfiles() {
  section "NOTES: dotfiles — lane assignments"
  cat <<'DOTFILES'
## Dotfile repo lane assignments (decided 2026-05-31)

  U.Dot (ITI-Theory/U.Dot)   — AUTHORITATIVE for all U-lane machines:
                                  - P14s WSL2 (Debian trixie + XFCE4 + awesomeWM)
                                  - Tablets (PRoot Debian bookworm, via Ansible)
                                Contains: i3/config, picom/picom.conf,
                                          bash/{MINGW64,ubuntu}/, bin/HAL1

  T.Dot (ITI-Theory/T.Dot)   — HAL master router + cross-device bootstrap
                                Contains: bin/HAL (dispatcher), bin/HAL0,
                                          provisioning/tablets/

  Me/Dot (Alistair-Johnson/Me/Dot)
                              — STAGING ONLY. i3/config + picom.conf created
                                May 13 2026 but identical to U.Dot defaults.
                                Do NOT use for provisioning. Can be deleted.

## Provisioning path
  P14s WSL2:  clone T.Dot → HAL init → HAL sync → U.Dot clone → symlinks
  Tablets:    ansible-playbook T.Dot/provisioning/tablets/site.yml (does all of above)

## Symlink targets (inside WSL2 Arch or tablet PRoot Arch)
  ~/.config/i3/config       → ~/prj/git/ITI-Theory/U.Dot/i3/config
  ~/.config/picom/picom.conf → ~/prj/git/ITI-Theory/U.Dot/picom/picom.conf
  ~/.bashrc                  → ~/prj/git/ITI-Theory/U.Dot/bash/ubuntu/bashrc
  ~/.bash_profile            → ~/prj/git/ITI-Theory/U.Dot/bash/ubuntu/profile

DOTFILES
}

_notes_stack() {
  section "NOTES: stack — device stack overview"
  cat <<'STACK'
## Device stack (as of 2026-06)

### P14s (Lenovo ThinkPad P14s — primary machine)
  OS:      Windows 11
  WSL2:    Debian (trixie) + XFCE4 + awesomeWM
  Dotfiles: U.Dot
  Key apps (Windows):
    Ableton Live Suite  — audio engine
    Bome MIDI Translator Pro  — MIDI routing (Twisters → virtual port)
    Bitfocus Companion  — Stream Deck XL control
    InputLeap server    — keyboard/mouse sharing (when WSL2 is elected host)
    VcXsrv              — full-screen X server for WSL2 display (config.xlaunch in T.Dot/bin)
    AutoHotKey          — key remapping (¦→|, knob→WSL2 bridge)
  Key apps (WSL2 Debian):
    Python field server  — soma-field instrument core
    xpra                 — auto-attaches to elected host session (HAL wsl2 startx)
    InputLeap client     — auto-connects to elected host (HAL wsl2 startx)

### 3× Lenovo IdeaPad Tablets
  OS:      Android + Termux
  Layer:   proot → Debian (bookworm) + XFCE4 + awesomeWM
  Dotfiles: U.Dot (via Ansible symlinks)
  IPs:     .207 (u0_a304) | .219 (u0_a360) | .110 (u0_a297)
  Key apps:
    Termux-X11       — display server (preferred over VNC — no compression)
                       Termux-side companion: installed by Ansible (termux-x11-nightly)
                       Android APK: manual sideload required
                         → https://github.com/termux/termux-x11/releases
                         Download .apk, install on tablet, launch before starting X apps
    InputLeap client — auto-connects to elected host (HAL tablets start)
    Python/OSC       — receives field state from server

### Host election (dynamic — no hardcoded server)
  Any machine can be elected host: HAL host start
  Host advertises via avahi: _xpra._tcp (port 6010) + _barrier._tcp (port 24800)
  Clients discover automatically during HAL wsl2 startx / HAL tablets start
  Current host: run 'avahi-browse -t _xpra._tcp' to see who is advertising

### Keyboard/mouse sharing: InputLeap (Barrier lineage)
  Synergy → Barrier → InputLeap — current active maintained fork.
  Server: elected host machine (HAL host start barrier)
  Clients: all other machines — auto-connect via avahi discovery
  Mouse slides off screen edge → control moves to next device.
  Shared clipboard included.
  Install: https://github.com/input-leap/input-leap

### Display teleportation: Xpra
  Elected host runs Xpra server :10 (HAL host start xpra)
  All other machines auto-attach (HAL wsl2 startx / HAL tablets start)
  App runs on host CPU; only pixels travel over LAN.

### Soma-field instrument roles per device
  P14s (Windows):  Ableton Live + Bome + Companion
  P14s (WSL2):     Python field server — the physics brain
  Tablet 1:        OSC monitor / field state display
  Tablet 2:        Extended Stream Deck (Companion remote panel)
  Tablet 3:        TouchDesigner preview / fractal mirror

STACK
}

# ---------------------------------------------------------------------------
# HAL status — aggregate state check across all subsystems
# ---------------------------------------------------------------------------

do_status() {
  banner "HAL status — $(date '+%Y-%m-%d %H:%M')"

  section "HOST"
  _host_status_check

  section "WSL2"
  _wsl2_status_check

  section "TABLETS"
  _tablet_check
}

# ---------------------------------------------------------------------------
# HAL tablets — implementation module (source from HAL-tablets)
# ---------------------------------------------------------------------------

_hal_source HAL0-tablets

# ---------------------------------------------------------------------------
# HAL wsl2 — WSL2 desktop commands (source from HAL0-wsl2)
# ---------------------------------------------------------------------------

_hal_source HAL0-wsl2

# ---------------------------------------------------------------------------
# HAL host — host role election (source from HAL0-host)
# ---------------------------------------------------------------------------

_hal_source HAL0-host

# ---------------------------------------------------------------------------
# HAL sync — pull-first across all known repos
# ---------------------------------------------------------------------------

do_sync() {
  banner "HAL sync — $(date '+%Y-%m-%d %H:%M')"
  local always=("T" "T.Ops" "T.Dot")
  local optional=("U" "U.Dot" "U.Ops")

  for repo in "${always[@]}"; do
    echo "=== $repo ==="
    git -C "$ITI/$repo" pull --ff-only && echo "[ok]" \
      || echo "[WARNING: pull failed — run: git -C $ITI/$repo pull]"
  done

  for repo in "${optional[@]}"; do
    local rpath="$ITI/$repo"
    [[ -d "$rpath/.git" ]] || continue
    echo "=== $repo ==="
    git -C "$rpath" pull --ff-only && echo "[ok]" \
      || echo "[WARNING: pull failed — run: git -C $rpath pull]"
  done

  if [[ -d "$ME_REPO/.git" ]]; then
    echo "=== Me ==="
    git -C "$ME_REPO" pull --ff-only && echo "[ok]" \
      || echo "[WARNING: pull failed — run: git -C $ME_REPO pull]"
  fi
}

# ---------------------------------------------------------------------------
# HAL provision — run Ansible playbook against this machine
# ---------------------------------------------------------------------------

do_provision() {
  local limit="${1:-}"
  local playbook="$REPO_ROOT/provisioning/tablets/site.yml"
  local inventory="$REPO_ROOT/provisioning/tablets/hosts"

  # Always pull T.Dot before provisioning — ensures playbook is current
  echo "[HAL] Syncing T.Dot before provision..."
  git -C "$REPO_ROOT" pull --ff-only 2>&1 | sed 's/^/  /'

  if [[ ! -f "$playbook" ]]; then
    echo "[HAL] ERROR: playbook not found at $playbook" >&2
    exit 1
  fi

  # Auto-detect limit if not provided
  if [[ -z "$limit" ]]; then
    if [[ -n "${TERMUX_VERSION:-}" ]] || [[ -d /data/data/com.termux ]]; then
      limit="tablets"
    else
      limit="wsl2"
    fi
    echo "[HAL] Auto-detected limit: $limit"
  fi

  echo "[HAL] Running: ansible-playbook --limit $limit"
  ansible-playbook -i "$inventory" "$playbook" --limit "$limit" "${@:2}"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

usage() {
  cat <<'USAGE'
HAL0 — T-lane base layer

Usage:
  HAL0 prime [pack ...] [-c|--clip]
                         Output AI context block to stdout.
                         Add -c or --clip to also copy to clipboard
                         (auto-detects: xclip / wl-copy / clip / termux-clipboard-set)
                         Optional packs (add after prime):
                           papers   — all U paper source .md files
                           lean     — all U/paper/proofs .lean proof files
                           process  — U/PROCESS.md in full
                           issues   — open GitHub issues across T.Ops, U, U.Ops
                           tablets  — tablet IPs, bootstrap, Termux:X11, Ansible reference
                         Combine: HAL prime papers lean
  HAL0 notes <topic>     Quick reference for a topic (no AI context — just the facts)
                           tablets   — tablet bootstrap sequence, Termux:X11, IPs, roles
                           dotfiles  — which repo is authoritative for which device
                           stack     — full device stack: WSL2 vs tablets, InputLeap, Xpra
  HAL0 tablets save-ips     Save tablet IPs to ~/.config/hal/tablet-ips (use when reachable)
  HAL0 tablets ping      mDNS + SSH diagnostic: avahi-resolve → ping → SSH per tablet
  HAL0 tablets check     Full state: ssh/sshd/X11/xfce/barrier per tablet
  HAL0 tablets battery   Open battery-optimization exemption dialog on all 3 tablets
  HAL0 tablets boot-install  Install termux-services runit sshd + Termux:Boot script (one-time)
  HAL0 tablets start [N] Start X11+XFCE4+Barrier (pre+post check, aborts if down)
  HAL0 tablets sshd      Restart sshd on all 3 tablets + post-check
  HAL0 tablets fix-phantom [p1 p2 p3]
                         Disable Android 12+ Phantom Process Killer via ADB (default port: 5555)
  HAL0 tablets pair <pp1> <pp2> <pp3>
                         One-time ADB Wireless pairing (runs adb pair interactively per tablet)
  HAL0 wsl2 start        Start avahi + dbus services
  HAL0 wsl2 stop         Stop non-essential services
  HAL0 wsl2 startx       VcXsrv full-screen → XFCE4 + awesomeWM → auto-attach xpra + barrier
  HAL0 wsl2 stopx        Kill desktop, VcXsrv, xpra attach, barrier client
  HAL0 wsl2 ping         4-step mDNS diagnostic (avahi → dnsTunneling → resolve → ping)
  HAL0 wsl2 check        Show WSL2 state (expected vs actual)
  HAL0 host start [xpra] [barrier]
                         Elect this machine as host. Start Xpra server + Barrier server.
                         Advertises via avahi. Warns if another host already present.
  HAL0 host stop [xpra] [barrier]
                         Stop host servers + withdraw avahi advertisements
  HAL0 host check        Show host state (expected vs actual)
  HAL0 status            Aggregate state: host + wsl2 + tablets in one view
  HAL0 sync              Pull --ff-only on all known repos (pull-first discipline)
  HAL0 provision [limit] Run Ansible playbook against this machine.
                         limit: wsl2 (default on WSL2) or tablets (default on Termux)
                         Extra args passed through: HAL provision wsl2 --tags dotfiles
  HAL0 init              Install HAL0 + HAL dispatcher into ~/.local/bin + selftest
  HAL0 selftest          Verify installation: wrappers, modules, PATH
  HAL0 help              Show this help

USAGE
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  prime)
    _hal_selftest --quiet || exit 1
    _hal_clip() {
      if [[ -n "${TERMUX_VERSION:-}" ]] || command -v termux-clipboard-set &>/dev/null; then
        termux-clipboard-set
      elif [[ -n "${WAYLAND_DISPLAY:-}" ]] && command -v wl-copy &>/dev/null; then
        wl-copy
      elif command -v xclip &>/dev/null; then
        xclip -selection clipboard
      else
        clip 2>/dev/null || { cat > /dev/null; echo "[HAL] No clipboard tool found — install xclip (X11) or wl-copy (Wayland)" >&2; }
      fi
    }
    # Check for --clip / -c flag anywhere in args
    do_clip=0
    packs=()
    for arg in "$@"; do
      case "$arg" in
        --clip|-c) do_clip=1 ;;
        *) packs+=("$arg") ;;
      esac
    done
    _run_prime() {
      do_prime
      for pack in "${packs[@]+"${packs[@]}"}"; do
        case "$pack" in
          papers)  pack_papers  ;;
          lean)    pack_lean    ;;
          process) pack_process ;;
          issues)  pack_issues  ;;
          tablets) pack_tablets ;;
          *)       echo "[HAL] Unknown pack: $pack (available: papers lean process issues tablets)" ;;
        esac
      done
      echo ""
      banner "END HAL prime — paste above into any AI session"
    }
    if (( do_clip )); then
      _run_prime | tee >(_hal_clip)
      echo "" >&2
      echo "[HAL] Copied to clipboard." >&2
    else
      _run_prime
    fi
    ;;
  init)      do_init ;;
  selftest)  _hal_selftest ;;
  sync)      _hal_selftest --quiet || exit 1; do_sync ;;
  provision) _hal_selftest --quiet || exit 1; do_provision "$@" ;;
  notes)     _hal_selftest --quiet || exit 1; do_notes "${1:-}" ;;
  tablets)   _hal_selftest --quiet || exit 1; do_tablets "$@" ;;
  wsl2)      _hal_selftest --quiet || exit 1; do_wsl2 "$@" ;;
  status)    _hal_selftest --quiet || exit 1; do_status ;;
  host)      _hal_selftest --quiet || exit 1; do_host "$@" ;;
  help|-h|--help) usage ;;
  *)
    echo "[HAL] Unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac

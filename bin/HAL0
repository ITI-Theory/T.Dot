#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
# T.Dot lives inside ITI-Theory/ — sibling repos are one level up
ITI="$(cd -- "$REPO_ROOT/.." && pwd)"
ME_REPO="$(cd -- "$ITI/../Me" 2>/dev/null && pwd)" || ME_REPO="$HOME/prj/git/Me"

# ---------------------------------------------------------------------------
# Utilities
# ---------------------------------------------------------------------------

section() { echo ""; echo "--- $* ---"; }
banner()  { echo "================================================================"; echo "=== $*"; echo "================================================================"; }

# ---------------------------------------------------------------------------
# HAL init — symlink HAL into PATH
# ---------------------------------------------------------------------------

do_init() {
  mkdir -p "$HOME/.local/bin"
  ln -sfn "$SCRIPT_DIR/HAL0" "$HOME/.local/bin/HAL0"
  ln -sfn "$SCRIPT_DIR/HAL"  "$HOME/.local/bin/HAL"
  echo "[HAL0] init complete — HAL0 and HAL dispatcher linked to ~/.local/bin"
  echo "[HAL0] Ensure ~/.local/bin is in PATH (add to ~/.bashrc if needed)"
}

# ---------------------------------------------------------------------------
# HAL prime — base context block
# ---------------------------------------------------------------------------

do_prime() {
  banner "HAL prime — $(date '+%Y-%m-%d %H:%M')"

  section "MASTER INSTRUCTIONS (T/.github/copilot-instructions.md)"
  if [[ -f "$ITI/T/.github/copilot-instructions.md" ]]; then
    cat "$ITI/T/.github/copilot-instructions.md"
  else
    echo "[HAL] WARNING: T master instructions not found"
  fi

  section "U INSTRUCTIONS (U/.github/copilot-instructions.md)"
  if [[ -f "$ITI/U/.github/copilot-instructions.md" ]]; then
    cat "$ITI/U/.github/copilot-instructions.md"
  else
    echo "[HAL] WARNING: U instructions not found"
  fi

  section "FIELD-NOTES (last 40 lines)"
  if [[ -f "$ITI/U/paper/FIELD-NOTES.md" ]]; then
    tail -40 "$ITI/U/paper/FIELD-NOTES.md"
  else
    echo "[HAL] WARNING: FIELD-NOTES.md not found"
  fi

  section "GIT STATUS"
  for repo in U T.Ops Me; do
    local rpath
    if [[ "$repo" == "Me" ]]; then
      rpath="$ME_REPO"
    else
      rpath="$ITI/$repo"
    fi
    echo "=== $repo ==="
    if [[ -d "$rpath/.git" ]]; then
      git -C "$rpath" status -sb
    else
      echo "[not found at $rpath]"
    fi
  done
}

# ---------------------------------------------------------------------------
# Packs — loaded on top of base prime
# ---------------------------------------------------------------------------

pack_papers() {
  section "PACK: papers — U paper source files"
  local paper_dir="$ITI/U/paper"
  if [[ ! -d "$paper_dir" ]]; then
    echo "[HAL] WARNING: paper dir not found at $paper_dir"; return
  fi
  # Each paper lives in paper/soma/<name>/<name>.md (or ai-method/<name>/<name>.md)
  while IFS= read -r -d '' f; do
    echo ""
    echo "### FILE: $f ###"
    cat "$f"
  done < <(find "$paper_dir/soma" "$paper_dir/ai-method" -mindepth 2 -maxdepth 2 -name "*.md" -print0 2>/dev/null | sort -z)
}

pack_lean() {
  section "PACK: lean — U/paper/proofs Lean 4 source files"
  local src_dir="$ITI/U/paper/proofs"
  if [[ ! -d "$src_dir" ]]; then
    echo "[HAL] WARNING: proofs dir not found at $src_dir"; return
  fi
  while IFS= read -r -d '' f; do
    echo ""
    echo "### FILE: $f ###"
    cat "$f"
  done < <(find "$src_dir" -name "*.lean" -print0 | sort -z)
}

pack_process() {
  section "PACK: process — U/PROCESS.md"
  if [[ -f "$ITI/U/PROCESS.md" ]]; then
    cat "$ITI/U/PROCESS.md"
  else
    echo "[HAL] WARNING: PROCESS.md not found"
  fi
}

pack_tablets() {
  section "PACK: tablets — Tablet bootstrap & Xpra reference"
  cat <<'TABLETS'
## Tablet Setup Reference (3× Lenovo IdeaPad, Android/Termux)

### IPs and users (LAN 192.168.1.x)
  Tablet 1:  u0_a304 @ 10.205.183.207  port 8022
  Tablet 2:  u0_a360 @ 10.205.183.219  port 8022
  Tablet 3:  u0_a297 @ 10.205.183.110  port 8022

### Bootstrap sequence — do this in order

  Step 1 (on each tablet, manually):
    pkg install openssh && sshd
    whoami          # note your u0_aNNN username
    ifconfig wlan0  # confirm IP

  Step 2 (from P14s WSL2 — once per tablet):
    ssh-keygen -t ed25519 -N "" -f ~/.ssh/id_ed25519   # if not already done
    ssh-copy-id -p 8022 u0_a304@10.205.183.207
    ssh-copy-id -p 8022 u0_a360@10.205.183.219
    ssh-copy-id -p 8022 u0_a297@10.205.183.110

  Step 3 (from P14s WSL2 — automation):
    ansible-playbook T.Dot/provisioning/tablets/site.yml
    # Installs: PRoot, Arch, XFCE4, Xpra, clones dotfiles

  Step 4 (optional — InputLeap):
    InputLeap server on P14s (Windows binary)
    InputLeap client inside each tablet's PRoot Arch

### Xpra — "screen for X11" (the display-teleport app)
  What it does: run an app on machine A, view/interact with it on machine B.
  The app keeps running on A's CPU — only the display moves.

  Start a session on source machine (P14s WSL2 — Arch):
    xpra start :100 --start-child=xfce4-session

  Attach from a tablet (inside PRoot Arch):
    xpra attach xpra:192.168.1.NNN:100

  Teleport back:
    detach (close the xpra window on tablet) → re-attach from source

  Install:
    sudo pacman -S xpra        # Arch
    sudo apt install xpra      # Ubuntu/Debian (inside PRoot)

### Tablet roles (soma-field instrument)
  Tablet 1:  OSC monitor / field state display (Xpra → Python server output)
  Tablet 2:  Extended Stream Deck surface (Bitfocus Companion remote panel)
  Tablet 3:  TouchDesigner preview / fractal output mirror

### Why Ansible (not manual):
  Three tablets, identical setup. Do it once in a playbook, replay on all three.
  Ansible needs SSH key auth first (Step 2 above) — it cannot bootstrap Termux itself.
  Playbook lives at: T.Dot/provisioning/tablets/site.yml
  Inventory at:      T.Dot/provisioning/tablets/hosts

### PRoot — what it actually is:
  "PRoot" = ptrace-based root emulation. NOT real root.
  proot-distro uses the Linux ptrace syscall to intercept filesystem calls and
  fake a root environment. Inside the container you appear as uid 0 but:
    - Real kernel ops fail: mount, modprobe, loading modules
    - File I/O, pacman, running servers all work (ptrace redirects them)
    - sshd on port 8022 works because Android allows app-user ports >1024
  The Termux home (/data/data/com.termux/files/home) is bind-mounted into
  proot at /termux-home — dotfiles cloned in Termux are accessible inside Arch.
  Ansible uses become=false because there is no real privilege escalation.

TABLETS
}

pack_issues() {
  section "PACK: issues — open GitHub issues (requires gh CLI)"
  if ! command -v gh &>/dev/null; then
    echo "[HAL] WARNING: gh CLI not found — install from https://cli.github.com"; return
  fi
  for repo in ITI-Theory/T.Ops ITI-Theory/U ITI-Theory/U.Ops; do
    echo ""
    echo "=== $repo ==="
    gh issue list --repo "$repo" --state open --limit 50 \
      --json number,title,labels,updatedAt \
      --template '{{range .}}#{{.number}} {{.title}} [{{range .labels}}{{.name}} {{end}}] ({{.updatedAt | timeago}}){{"\n"}}{{end}}' \
      2>/dev/null || echo "[no issues or access error]"
  done
}

# ---------------------------------------------------------------------------
# HAL notes — quick human-readable reference for a topic
# ---------------------------------------------------------------------------

do_notes() {
  local topic="${1:-}"
  case "$topic" in
    tablets)  pack_tablets ;;
    dotfiles) _notes_dotfiles ;;
    stack)    _notes_stack ;;
    *)
      echo "HAL notes <topic>"
      echo ""
      echo "Available topics:"
      echo "  tablets   — tablet IPs, bootstrap sequence, Xpra, Ansible, roles"
      echo "  dotfiles  — which dotfile repo is authoritative for which device"
      echo "  stack     — full device stack: what runs on P14s WSL2 vs tablets"
      ;;
  esac
}

_notes_dotfiles() {
  section "NOTES: dotfiles — lane assignments"
  cat <<'DOTFILES'
## Dotfile repo lane assignments (decided 2026-05-31)

  U.Dot (ITI-Theory/U.Dot)   — AUTHORITATIVE for all U-lane machines:
                                  - P14s WSL2 (Arch + XFCE4)  ← only notebook
                                  - Tablets (PRoot Arch, via Ansible)
                                Contains: i3/config, picom/picom.conf,
                                          bash/{MINGW64,ubuntu}/, bin/HAL1

  T.Dot (ITI-Theory/T.Dot)   — HAL master router + cross-device bootstrap
                                Contains: bin/HAL (dispatcher), bin/HAL0,
                                          provisioning/tablets/

  Me/Dot (Alistair-Johnson/Me/Dot)
                              — STAGING ONLY. i3/config + picom.conf created
                                May 13 2026 but identical to U.Dot defaults.
                                Do NOT use for provisioning. Can be deleted.

## Provisioning path
  P14s WSL2:  clone T.Dot → HAL init → HAL sync → U.Dot clone → symlinks
  Tablets:    ansible-playbook T.Dot/provisioning/tablets/site.yml (does all of above)

## Symlink targets (inside WSL2 Arch or tablet PRoot Arch)
  ~/.config/i3/config       → ~/prj/git/ITI-Theory/U.Dot/i3/config
  ~/.config/picom/picom.conf → ~/prj/git/ITI-Theory/U.Dot/picom/picom.conf
  ~/.bashrc                  → ~/prj/git/ITI-Theory/U.Dot/bash/ubuntu/bashrc
  ~/.bash_profile            → ~/prj/git/ITI-Theory/U.Dot/bash/ubuntu/profile

DOTFILES
}

_notes_stack() {
  section "NOTES: stack — device stack overview"
  cat <<'STACK'
## Device stack (as of 2026-05-31)

### P14s (Lenovo ThinkPad P14s — primary machine)
  OS:      Windows 11
  WSL2:    Arch Linux + XFCE4 + i3 + picom + conky
  Dotfiles: U.Dot (i3, picom, bash)
  Key apps (Windows):
    Ableton Live Suite  — audio engine
    Bome MIDI Translator Pro  — MIDI routing (Twisters → virtual port)
    Bitfocus Companion  — Stream Deck XL control
    InputLeap server    — keyboard/mouse sharing SERVER (shares P14s kbd+mouse)
    VcXsrv              — X server for WSL2 display
    AutoHotKey          — key remapping (¦→|, knob→WSL2 bridge)
  Key apps (WSL2 Arch):
    Python field server  — soma-field instrument core
    xpra                 — display teleportation (start sessions here)
    InputLeap client     — receives kbd/mouse from server when needed

### 3× Lenovo IdeaPad Tablets
  OS:      Android + Termux
  Layer:   PRoot → Arch Linux + XFCE4 + xpra + picom + conky
  Dotfiles: U.Dot (via Ansible symlinks)
  IPs:     .207 (u0_a304) | .219 (u0_a360) | .110 (u0_a297)
  Key apps:
    Termux-X11       — display server (preferred over VNC — no compression)
                       Termux-side companion: installed by Ansible (termux-x11-nightly)
                       Android APK: manual sideload required
                         → https://github.com/termux/termux-x11/releases
                         Download .apk, install on tablet, launch before starting X apps
    xpra client      — attach to sessions running on P14s WSL2
    InputLeap client — shares P14s keyboard/mouse onto tablet screen
    Python/OSC       — receives field state from server

### Keyboard/mouse sharing: InputLeap
  Consensus across multiple chat sessions: InputLeap is the current
  active maintained project (Synergy → Barrier → InputLeap lineage).
  Server: P14s Windows (shares the physical Keychron + trackball)
  Clients: WSL2 Arch + all 3 tablets (Termux PRoot Arch)
  Mouse slides off screen edge → control moves to next device.
  Shared clipboard included.
  Install: https://github.com/input-leap/input-leap

### Display teleportation: Xpra
  Start a session on P14s WSL2, view/interact from any tablet.
  App runs on P14s CPU; only the pixels travel over LAN.
  See: HAL notes tablets

### Soma-field instrument roles per device
  P14s (Windows):  Ableton Live + Bome + Companion
  P14s (WSL2):     Python field server — the physics brain
  Tablet 1:        OSC monitor / field state display
  Tablet 2:        Extended Stream Deck (Companion remote panel)
  Tablet 3:        TouchDesigner preview / fractal mirror

STACK
}

# ---------------------------------------------------------------------------
# HAL tablets — remote tablet management
# ---------------------------------------------------------------------------

T1="u0_a304@10.133.134.207"
T2="u0_a360@10.133.134.219"
T3="u0_a297@10.133.134.110"
SSH_OPTS="-p 8022 -o ConnectTimeout=6 -o BatchMode=yes"

_tablet_ssh() {
  local host="$1"; shift
  ssh $SSH_OPTS "$host" "$@"
}

do_tablets() {
  local sub="${1:-help}"
  shift || true
  case "$sub" in
    battery)
      echo "=== Triggering battery-optimization exemption dialog on all 3 tablets ==="
      echo "(You must tap 'Allow' on each tablet screen when the dialog appears)"
      for host in "$T1" "$T2" "$T3"; do
        echo ""
        echo "--- $host ---"
        _tablet_ssh "$host" \
          'am start -a android.settings.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS -d "package:com.termux" && sleep 1 && am start -a android.settings.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS -d "package:com.termux.x11"' \
          && echo "[ok] dialog launched — tap Allow on tablet" \
          || echo "[FAILED] ssh connect failed"
      done
      echo ""
      echo "After tapping Allow × 2 per tablet, run: HAL tablets start"
      ;;
    start)
      local name="${1:-}"
      if [[ -n "$name" ]]; then
        # Start a single named tablet
        case "$name" in
          1|Tablet1) _do_start_one "$T1" Tablet1 ;;
          2|Tablet2) _do_start_one "$T2" Tablet2 ;;
          3|Tablet3) _do_start_one "$T3" Tablet3 ;;
          *) echo "[HAL] Unknown tablet: $name (use 1/2/3 or Tablet1/Tablet2/Tablet3)" ;;
        esac
      else
        echo "=== Starting desktops on all 3 tablets in parallel ==="
        _do_start_one "$T1" Tablet1 &
        _do_start_one "$T2" Tablet2 &
        _do_start_one "$T3" Tablet3 &
        wait
        echo "=== all done ==="
      fi
      ;;
    sshd)
      echo "=== Restarting sshd on all 3 tablets ==="
      for host in "$T1" "$T2" "$T3"; do
        echo "--- $host ---"
        _tablet_ssh "$host" 'pkill sshd 2>/dev/null; sleep 1; sshd && echo "[ok] sshd started"' \
          || echo "[FAILED] connect failed"
      done
      ;;
    status)
      echo "=== Tablet SSH status ==="
      for host in "$T1" "$T2" "$T3"; do
        echo -n "$host: "
        _tablet_ssh "$host" \
          'echo "up | sshd=$(pgrep sshd|wc -l) | tmux=$(tmux -S /data/data/com.termux/files/usr/tmp/tmux.sock list-sessions 2>/dev/null | wc -l) sessions"' \
          || echo "DOWN (connection refused)"
      done
      ;;
    help|*)
      cat <<'TUSAGE'
HAL tablets <subcommand>

  battery        Open battery-optimization exemption dialog on all tablets
                 (you tap Allow × 2 per tablet, then run 'start')
  sshd           Restart sshd on all tablets (when SSH is already up)
  start [N]      Run start-desktop.sh on all tablets (or just 1/2/3)
  status         Quick SSH ping — shows up/down + tmux session count
  help           Show this help
TUSAGE
      ;;
  esac
}

_do_start_one() {
  local host="$1" name="$2"
  echo "--- $name ($host) ---"
  ssh $SSH_OPTS "$host" bash <<ENDSSH
T=/data/data/com.termux/files/usr/tmp
SOCK=\$T/tmux.sock
NAME=$name
BARRIER=10.133.134.136

echo "[start-desktop] \$NAME — \$(date)"
termux-wake-lock && echo "[ok] wakelock" || echo "[warn] wakelock failed (not fatal)"
pkill -f xfce4-session 2>/dev/null; pkill -f barrierc 2>/dev/null; pkill -f termux-x11 2>/dev/null
tmux -S "\$SOCK" kill-server 2>/dev/null
sleep 1
am start -n com.termux.x11/.MainActivity
sleep 1
TMPDIR=\$T termux-x11 :0 &
sleep 3
ls "\$T/.X11-unix/" 2>/dev/null && echo "[ok] X11 socket" || { echo "[error] X11 socket missing — is Termux:X11 APK installed?"; exit 1; }
tmux -S "\$SOCK" new-session -d -s xfce \
  "TMPDIR=\$T proot-distro login debian --bind ~/:/termux-home --bind \$T/.X11-unix:/tmp/.X11-unix -- bash -c 'DISPLAY=:0 dbus-run-session -- xfce4-session'"
sleep 4
echo "[ok] xfce tmux session"
tmux -S "\$SOCK" new-session -d -s barrier \
  "TMPDIR=\$T proot-distro login debian --bind ~/:/termux-home --bind \$T/.X11-unix:/tmp/.X11-unix -- bash -c 'while true; do DISPLAY=:0 barrierc --no-tray --disable-crypto --name \$NAME --display :0 \$BARRIER; sleep 3; done'"
sleep 2
echo "[ok] barrier tmux session"
echo "--- Sessions ---"
tmux -S "\$SOCK" list-sessions
echo "[done]"
ENDSSH
}

# ---------------------------------------------------------------------------
# HAL sync — pull-first across all known repos
# ---------------------------------------------------------------------------

do_sync() {
  banner "HAL sync — $(date '+%Y-%m-%d %H:%M')"
  local always=("T" "T.Ops" "T.Dot")
  local optional=("U" "U.Dot" "U.Ops")

  for repo in "${always[@]}"; do
    echo "=== $repo ==="
    git -C "$ITI/$repo" pull --ff-only && echo "[ok]" \
      || echo "[WARNING: pull failed — run: git -C $ITI/$repo pull]"
  done

  for repo in "${optional[@]}"; do
    local rpath="$ITI/$repo"
    [[ -d "$rpath/.git" ]] || continue
    echo "=== $repo ==="
    git -C "$rpath" pull --ff-only && echo "[ok]" \
      || echo "[WARNING: pull failed — run: git -C $rpath pull]"
  done

  if [[ -d "$ME_REPO/.git" ]]; then
    echo "=== Me ==="
    git -C "$ME_REPO" pull --ff-only && echo "[ok]" \
      || echo "[WARNING: pull failed — run: git -C $ME_REPO pull]"
  fi
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

usage() {
  cat <<'USAGE'
HAL0 — T-lane base layer

Usage:
  HAL0 prime [pack ...] [-c|--clip]
                         Output AI context block to stdout.
                         Add -c or --clip to also copy to clipboard
                         (auto-detects: xclip / wl-copy / clip / termux-clipboard-set)
                         Optional packs (add after prime):
                           papers   — all U paper source .md files
                           lean     — all U/paper/proofs .lean proof files
                           process  — U/PROCESS.md in full
                           issues   — open GitHub issues across T.Ops, U, U.Ops
                           tablets  — tablet IPs, bootstrap, Xpra, Ansible reference
                         Combine: HAL prime papers lean
  HAL0 notes <topic>     Quick reference for a topic (no AI context — just the facts)
                           tablets   — tablet bootstrap sequence, Xpra, IPs, roles
                           dotfiles  — which repo is authoritative for which device
                           stack     — full device stack: WSL2 vs tablets, InputLeap, Xpra
  HAL0 tablets battery   Open battery-optimization exemption dialog on all 3 tablets
  HAL0 tablets start [N] Run start-desktop.sh on all tablets (or just 1/2/3)
  HAL0 tablets sshd      Restart sshd on all 3 tablets
  HAL0 tablets status    SSH ping — up/down + tmux session count
  HAL0 sync              Pull --ff-only on all known repos (pull-first discipline)
  HAL0 init              Link HAL0 + HAL dispatcher into ~/.local/bin
  HAL0 help              Show this help

USAGE
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  prime)
    _hal_clip() {
      if [[ -n "${TERMUX_VERSION:-}" ]] || command -v termux-clipboard-set &>/dev/null; then
        termux-clipboard-set
      elif [[ -n "${WAYLAND_DISPLAY:-}" ]] && command -v wl-copy &>/dev/null; then
        wl-copy
      elif command -v xclip &>/dev/null; then
        xclip -selection clipboard
      else
        clip 2>/dev/null || { cat > /dev/null; echo "[HAL] No clipboard tool found — install xclip (X11) or wl-copy (Wayland)" >&2; }
      fi
    }
    # Check for --clip / -c flag anywhere in args
    do_clip=0
    packs=()
    for arg in "$@"; do
      case "$arg" in
        --clip|-c) do_clip=1 ;;
        *) packs+=("$arg") ;;
      esac
    done
    _run_prime() {
      do_prime
      for pack in "${packs[@]+"${packs[@]}"}"; do
        case "$pack" in
          papers)  pack_papers  ;;
          lean)    pack_lean    ;;
          process) pack_process ;;
          issues)  pack_issues  ;;
          tablets) pack_tablets ;;
          *)       echo "[HAL] Unknown pack: $pack (available: papers lean process issues tablets)" ;;
        esac
      done
      echo ""
      banner "END HAL prime — paste above into any AI session"
    }
    if (( do_clip )); then
      _run_prime | tee >(_hal_clip)
      echo "" >&2
      echo "[HAL] Copied to clipboard." >&2
    else
      _run_prime
    fi
    ;;
  init)    do_init ;;
  sync)    do_sync ;;
  notes)   do_notes "${1:-}" ;;
  tablets) do_tablets "$@" ;;
  help|-h|--help) usage ;;
  *)
    echo "[HAL] Unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac

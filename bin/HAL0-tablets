#!/usr/bin/env bash
# HAL0-tablets — T-lane tablet implementation module
# Called via HAL0 dispatch. Never invoke directly.
# HAL1-tablets (if it ever exists) should source this first, then override.
# Contract (pre/post) is enforced by do_tablets() below.
#
# Defines: T1 T2 T3 SSH_OPTS
#          pack_tablets        — AI context pack (used by HAL prime tablets)
#          _tablet_check       — state check, returns 0 if ALL up
#          _do_start_one       — start X11+XFCE4+Barrier on one tablet
#          do_tablets          — dispatcher: check/battery/start/sshd/status/help

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

T1="u0_a304@tablet1.local"
T2="u0_a360@tablet2.local"
T3="u0_a297@tablet3.local"
SSH_OPTS="-p 8022 -o ConnectTimeout=6 -o BatchMode=yes -o ServerAliveInterval=30 -o ServerAliveCountMax=6"

# ---------------------------------------------------------------------------
# Notes pack (used by: HAL prime tablets)
# ---------------------------------------------------------------------------

pack_tablets() {
  section "PACK: tablets — Tablet bootstrap & Xpra reference"
  cat <<'TABLETS'
## Tablet Setup Reference (3× Lenovo IdeaPad, Android/Termux)

### IPs and users
  Tablet 1:  u0_a304 @ tablet1.local  port 8022
  Tablet 2:  u0_a360 @ tablet2.local  port 8022
  Tablet 3:  u0_a297 @ tablet3.local  port 8022

### Bootstrap sequence — do this in order

  Step 1 (on each tablet, manually):
    pkg install openssh && sshd
    whoami          # note your u0_aNNN username
    ifconfig wlan0  # confirm IP

  Step 2 (from P14s — once per tablet):
    ssh-keygen -t ed25519 -N "" -f ~/.ssh/id_ed25519   # if not already done
    ssh-copy-id -p 8022 u0_a304@tablet1.local
    ssh-copy-id -p 8022 u0_a360@tablet2.local
    ssh-copy-id -p 8022 u0_a297@tablet3.local
    # First bootstrap (before avahi on WSL2): use the IP shown by ifconfig wlan0 on the tablet.

  Step 3 (from P14s — automation):
    ansible-playbook T.Dot/provisioning/tablets/site.yml
    # Installs: proot-distro, Debian bookworm, XFCE4, Barrier, dotfiles

  Step 4 (Barrier — Windows side):
    Barrier GUI → Configure Server → add Tablet1/Tablet2/Tablet3 in grid
    Screen name on each client must match exactly (capital T)
    SSL must be disabled: uncheck "Enable SSL" in GUI + --disable-crypto on client

### proot-distro
  Container name: debian  (Debian bookworm)
  Login: proot-distro login debian --bind ~/:/termux-home --bind $T/.X11-unix:/tmp/.X11-unix --
  Uses --kill-on-exit — wrap everything in tmux or it dies on SSH disconnect
  tmux socket (fixed path): /data/data/com.termux/files/usr/tmp/tmux.sock

### Termux:X11
  Android APK — sideload from https://github.com/termux/termux-x11/releases
  Launch: /system/bin/am start -n com.termux.x11/.MainActivity then TMPDIR=$T termux-x11 :0 &
  Socket: /data/data/com.termux/files/usr/tmp/.X11-unix/X0
  xkbcomp warnings: harmless, ignore them

### XFCE4
  Start inside proot: DISPLAY=:0 dbus-run-session -- xfce4-session
  (NOT dbus-launch — not present in bookworm dbus package)

### KVM — Barrier/Input Leap (Tablet2 is permanent server)
  Server: barriers (proot Debian on Tablet2) | tablet2.local:24800  [runit: barriers]
  Clients: Tablet1 (Tablet1 → tablet2.local), Tablet3 (Tablet3 → tablet2.local)  [runit: barrierc]
  Windows: input-leapc.exe --no-tray --disable-crypto --name Laptop-P14s -f tablet2.local
  Crypto disabled — --disable-crypto on all
  Clipboard sharing DISABLED (crashes Barrier 2.x on screen-switch)
  Screen layout:  [Tablet1] [Tablet2] [Tablet3]   (row)
                             [P14s]                (above Tablet2)
  Config (Tablet2 proot): /root/.config/barrier/barrier.conf  (written by Ansible)
  switchDelay = 500ms (prevents accidental screen switches at edge)

### Battery optimization (CRITICAL)
  Android kills Termux when screen turns off unless exempted.
  Run: HAL tablets battery  → tap Allow × 2 on each tablet
  Verify exemption: dumpsys deviceidle whitelist | grep termux

### Tablet roles (soma-field instrument)
  Tablet 1:  OSC monitor / field state display
  Tablet 2:  Extended Stream Deck surface (Bitfocus Companion remote panel)
  Tablet 3:  TouchDesigner preview / fractal output mirror

TABLETS
}

# ---------------------------------------------------------------------------
# Internal: state check
# ---------------------------------------------------------------------------

_tablet_check() {
  # Prints one status line per tablet to stdout.
  # Returns 0 only if ALL three are reachable over SSH.
  local all_ok=0
  for pair in "Tablet1:$T1" "Tablet2:$T2" "Tablet3:$T3"; do
    local label="${pair%%:*}" host="${pair#*:}"
    local result
    result=$(ssh $SSH_OPTS "$host" \
      'SOCK=/data/data/com.termux/files/usr/tmp/tmux.sock
       sshd_n=$(pgrep -c sshd 2>/dev/null || echo 0)
       SVDIR=/data/data/com.termux/files/usr/var/service
       x11=$( [[ -e /data/data/com.termux/files/usr/tmp/.X11-unix/X0 ]] && echo yes || echo no )
       xfce=$(sv status $SVDIR/tx11-xfce4 2>/dev/null | grep -c "^run"; true)
       barriers=$(sv status $SVDIR/barriers 2>/dev/null | grep -c "^run"; true)
       barrierc=$(sv status $SVDIR/barrierc 2>/dev/null | grep -c "^run"; true)
       boot=$( [[ -x ~/.termux/boot/start-services.sh ]] && echo yes || echo "NO-run:boot-install" )
       printf "ssh=up sshd=%s X11=%s xfce-svc=%s barriers-svc=%s barrierc-svc=%s boot=%s\n" \
         "$sshd_n" "$x11" "$xfce" "$barriers" "$barrierc" "$boot"' \
      2>/dev/null) || { echo "  $label ($host): SSH=DOWN"; all_ok=1; continue; }
    echo "  $label ($host): $result"
  done
  return $all_ok
}

# ---------------------------------------------------------------------------
# Internal: start one tablet
# ---------------------------------------------------------------------------

_do_start_one() {
  local host="$1" name="$2"
  echo "--- $name ($host) ---"

  SVDIR=/data/data/com.termux/files/usr/var/service
  # Determine service set locally, pass as expanded string into heredoc
  local svcs
  if [[ "$name" == "Tablet2" ]]; then
    svcs="tx11 tx11-xfce4 barriers"
  else
    svcs="tx11 tx11-xfce4 barrierc"
  fi

  ssh $SSH_OPTS "$host" bash <<ENDSSH
echo "[start] $name — \$(date)"
termux-wake-lock 2>/dev/null && echo "[ok] wakelock" || echo "[warn] wakelock failed (not fatal)"

# Ensure runsvdir is running
if ! pgrep -x runsvdir > /dev/null 2>&1; then
  nohup runsvdir $SVDIR > /dev/null 2>&1 & disown
  sleep 2; echo "[ok] runsvdir started"
else
  echo "[ok] runsvdir already running"
fi

# Bring up required services ($svcs)
for svc in $svcs; do
  sv up $SVDIR/\$svc 2>/dev/null && echo "[ok] sv up \$svc" || echo "[warn] \$svc not found — run: HAL provision tablets --tags boot"
done

echo "[status]"
sv status $SVDIR/tx11 $SVDIR/tx11-xfce4 $SVDIR/barriers $SVDIR/barrierc 2>/dev/null || true
ENDSSH

  echo "[done] $name — tap Termux:X11 icon on tablet if desktop not visible"
}

# ---------------------------------------------------------------------------
# Internal: start (or restart) the Barrier server in WSL2 tmux
# ---------------------------------------------------------------------------

_do_start_barrier_server() {
  # Launches Input Leap server (input-leaps.exe) in foreground.
  # NOTE: Barrier service (barrierd) is DISABLED — do not re-enable.
  # Config: C:/Users/alist/AppData/Local/Barrier/barrier.sgc
  #   clipboardSharing = false  (crashes on screen-switch in Barrier 2.x)
  #   screenSaverSync = false
  #   win32KeepForeground = false
  #   switchDelay = 500
  local il_exe="/c/Program Files/InputLeap/input-leaps.exe"
  local cfg="C:/Users/alist/AppData/Local/Barrier/barrier.sgc"

  if tasklist.exe 2>/dev/null | grep -qi 'input-leaps'; then
    echo "[ok] input-leaps.exe already running"
    return 0
  fi

  if [[ ! -f "$il_exe" ]]; then
    echo "[ABORT] Input Leap not found at: $il_exe"
    echo "        Download: https://github.com/input-leap/input-leap/releases"
    return 1
  fi

  echo "[info] Starting Input Leap server..."
  # Run detached via powershell Start-Process so it survives terminal close
  powershell.exe -NoProfile -Command \
    "Start-Process '${il_exe//\//\\\\}' -ArgumentList '-f','--no-tray','--disable-crypto','--name','Laptop-P14s','-c','${cfg}','--address',':24800' -WindowStyle Hidden" \
    2>/dev/null
  sleep 2

  if tasklist.exe 2>/dev/null | grep -qi 'input-leaps'; then
    echo "[ok] input-leaps.exe started — port 24800"
  else
    echo "[WARN] input-leaps.exe did not start — check manually"
  fi
}

# ---------------------------------------------------------------------------
# do_tablets — public dispatcher (contract: pre → impl → post)
# ---------------------------------------------------------------------------

do_tablets() {
  local sub="${1:-help}"
  shift || true

  # Always show current state before doing anything (except help)
  local pre_ok=0
  if [[ "$sub" != "help" ]]; then
    echo "=== State ==="
    _tablet_check || pre_ok=$?
    echo ""
  fi

  case "$sub" in

    check|status)
      # State already printed above — nothing more to do
      ;;

    battery)
      # Android 12+ blocks am start from SSH (UID mismatch) — must be done locally on each tablet.
      echo "=== Battery optimization exemption — MANUAL STEP REQUIRED ==="
      echo ""
      echo "On each tablet, open Termux locally and run:"
      echo "  /system/bin/am start -a android.settings.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS -d 'package:com.termux'"
      echo "  /system/bin/am start -a android.settings.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS -d 'package:com.termux.x11'"
      echo ""
      echo "Or: Settings → Apps → Termux → Battery → Unrestricted (repeat for Termux:X11)"
      echo ""
      echo "Current whitelist status:"
      for pair in "Tablet1:$T1" "Tablet2:$T2" "Tablet3:$T3"; do
        local label="${pair%%:*}" host="${pair#*:}"
        printf "  %s: " "$label"
        ssh $SSH_OPTS "$host" \
          'dumpsys deviceidle whitelist 2>/dev/null | grep -E "termux" || echo "NOT whitelisted"' \
          2>/dev/null || echo "[SSH DOWN]"
      done
      ;;

    barrier-server)
      # {P: running in WSL2} start barriers.exe in WSL2 tmux session {Q: port 24800 listening}
      echo "=== Starting Barrier server (WSL2-owned) ==="
      _do_start_barrier_server
      ;;

    start)
      # {P: all tablets ssh=up} start X11+XFCE4+Barrier {Q: xfce=1 barrier=1 per tablet}
      if [[ $pre_ok -ne 0 ]]; then
        echo "[ABORT] One or more tablets unreachable — cannot start."
        echo "        Open Termux on each tablet and run: sshd"
        return 1
      fi
      local name="${1:-}"
      if [[ -n "$name" ]]; then
        case "$name" in
          1|Tablet1) _do_start_one "$T1" Tablet1 ;;
          2|Tablet2) _do_start_one "$T2" Tablet2 ;;
          3|Tablet3) _do_start_one "$T3" Tablet3 ;;
          *) echo "[HAL] Unknown tablet: $name (use 1/2/3 or Tablet1/Tablet2/Tablet3)"; return 1 ;;
        esac
      else
        echo "=== Starting desktops on all 3 tablets in parallel ==="
        _do_start_one "$T1" Tablet1 &
        _do_start_one "$T2" Tablet2 &
        _do_start_one "$T3" Tablet3 &
        wait
      fi
      echo ""
      echo "=== Post-check ==="
      _tablet_check
      ;;

    sshd)
      # {P: Termux process alive} restart sshd {Q: sshd running}
      echo "=== Restarting sshd on all tablets ==="
      for pair in "Tablet1:$T1" "Tablet2:$T2" "Tablet3:$T3"; do
        local label="${pair%%:*}" host="${pair#*:}"
        printf "  %s: " "$label"
        ssh $SSH_OPTS "$host" 'pkill sshd 2>/dev/null; sleep 1; sshd && echo "[ok]"' \
          || echo "[FAILED] connect failed"
      done
      echo ""
      echo "=== Post-check ==="
      _tablet_check
      ;;

    stop)
      # {P: tablets reachable} stop X11+XFCE4+Barrier services
      echo "=== Stopping desktops on all tablets ==="
      for pair in "Tablet1:$T1" "Tablet2:$T2" "Tablet3:$T3"; do
        local label="${pair%%:*}" host="${pair#*:}"
        printf "  %s: " "$label"
        ssh $SSH_OPTS "$host" \
          'SVDIR=/data/data/com.termux/files/usr/var/service
           sv down $SVDIR/barriers   2>/dev/null || true
           sv down $SVDIR/barrierc   2>/dev/null || true
           sv down $SVDIR/tx11-xfce4 2>/dev/null || true
           sv down $SVDIR/tx11       2>/dev/null || true
           sleep 1
           pkill -x termux-x11 2>/dev/null || true
           pkill -x barrierc   2>/dev/null || true
           pkill -x barriers   2>/dev/null || true
           rm -f /data/data/com.termux/files/usr/tmp/.X11-unix/X*
           echo stopped' \
          2>/dev/null || echo "[FAILED]"
      done
      echo ""
      echo "=== Post-check ==="
      _tablet_check
      ;;

    boot-install)
      # {P: tablets reachable} install termux-services + runit sshd + Termux:Boot script
      # {Q: sshd supervised by runit; ~/.termux/boot/start-services.sh in place}
      echo "=== Installing termux-services + runit sshd on all tablets ==="
      echo ""
      for pair in "Tablet1:$T1" "Tablet2:$T2" "Tablet3:$T3"; do
        local label="${pair%%:*}" host="${pair#*:}"
        echo "--- $label ($host) ---"
        ssh $SSH_OPTS "$host" 'bash -s' <<'BOOTSCRIPT' || { echo "  [ABORT] $label — see above"; continue; }
# Pre-check: Termux:Boot APK must be installed for ~/.termux/boot/ to fire
if pm list packages 2>/dev/null | grep -q 'com.termux.boot'; then
  echo "[ok] Termux:Boot APK installed"
else
  echo "[ABORT] Termux:Boot APK NOT installed on this device"
  echo "        Install from: https://f-droid.org/packages/com.termux.boot/"
  echo "        or: https://github.com/termux/termux-boot/releases"
  echo "        Then re-run: HAL tablets boot-install"
  exit 1
fi
# Fix any half-configured packages before installing (avoids interactive conffile prompts)
DEBIAN_FRONTEND=noninteractive dpkg --configure -a --force-confold 2>/dev/null || true
DEBIAN_FRONTEND=noninteractive apt-get install -y -o Dpkg::Options::="--force-confold" termux-services
sv-enable sshd
sv up sshd 2>/dev/null || true
mkdir -p ~/.termux/boot
cat > ~/.termux/boot/start-services.sh << 'BOOTEOF'
#!/data/data/com.termux/files/usr/bin/sh
termux-wake-lock
. $PREFIX/etc/profile
BOOTEOF
chmod +x ~/.termux/boot/start-services.sh
echo "[ok] termux-services installed, sshd enabled under runit"
echo "[ok] boot script: ~/.termux/boot/start-services.sh"
sv status sshd 2>&1 || echo "(runit not running yet — active after next reboot)"
BOOTSCRIPT
        echo ""
      done
      echo "=== Post-check ==="
      _tablet_check
      ;;

    pair)
      # {P: adb installed; Wireless Debugging enabled + pairing code visible on each tablet}
      # One-time ADB pairing for all 3 tablets.
      # Usage: HAL tablets pair <p1> <p2> <p3>
      #   p1/p2/p3 = pairing ports shown under Developer Options → Wireless Debugging →
      #              "Pair device with pairing code" (NOT the "IP address & Port" port)
      # After pairing, run: HAL tablets fix-phantom <connect-p1> <connect-p2> <connect-p3>
      #   (connect ports are shown under "IP address & Port" in Wireless Debugging)
      local pp1="${1:?Usage: HAL tablets pair <pair-port1> <pair-port2> <pair-port3>}"
      local pp2="${2:?Usage: HAL tablets pair <pair-port1> <pair-port2> <pair-port3>}"
      local pp3="${3:?Usage: HAL tablets pair <pair-port1> <pair-port2> <pair-port3>}"

      local ADB=""
      if command -v adb &>/dev/null; then
        ADB="$(command -v adb)"
      elif [[ -f "/mnt/c/Users/alist/AppData/Local/Android/Sdk/platform-tools/adb.exe" ]]; then
        ADB="/mnt/c/Users/alist/AppData/Local/Android/Sdk/platform-tools/adb.exe"
      else
        echo "[ABORT] adb not found. Install: wsl -d Debian -- bash -l -c 'sudo apt-get install -y adb'"
        return 1
      fi
      echo "  adb: $ADB"
      echo ""

      echo "=== ADB Wireless Pairing ==="
      echo "    Tablet screen must be ON. Pairing code must be visible."
      echo ""

      local IPS=()
      for pair in "tablet1.local" "tablet2.local" "tablet3.local"; do
        IPS+=("$pair")
      done
      local PORTS=("$pp1" "$pp2" "$pp3")
      local NAMES=("Tablet1" "Tablet2" "Tablet3")

      for i in 0 1 2; do
        echo "--- ${NAMES[$i]} (${IPS[$i]}:${PORTS[$i]}) ---"
        echo "  Enter the 6-digit pairing code shown on ${NAMES[$i]}:"
        "$ADB" pair "${IPS[$i]}:${PORTS[$i]}"
        echo ""
      done
      echo "Pairing done. Now run: HAL tablets fix-phantom <connect-p1> <connect-p2> <connect-p3>"
      echo "(connect ports are under Developer Options → Wireless Debugging → 'IP address & Port')"
      ;;

    fix-phantom)
      # {P: adb installed, tablets paired via Wireless Debugging}
      # Disable Android 12+ Phantom Process Killer on all tablets via ADB.
      # {Q: settings_enable_monitor_phantom_procs=0, max_phantom_processes=2147483647}
      #
      # Prerequisites (one-time per tablet):
      #   1. Developer Options → Wireless Debugging → tap "Pair device with pairing code"
      #   2. adb pair <tablet-ip>:<pair-port>  (enter 6-digit code shown on tablet)
      #   3. Note port under "IP address & Port" — pass as args below
      #
      # Usage:
      #   HAL tablets fix-phantom                    # tries port 5555 on all tablets
      #   HAL tablets fix-phantom <p1> <p2> <p3>     # explicit per-tablet ports
      local p1="${1:-5555}" p2="${2:-5555}" p3="${3:-5555}"
      echo "=== Disabling Phantom Process Killer on all tablets ==="
      echo "    Ports: Tablet1=$p1  Tablet2=$p2  Tablet3=$p3"
      echo ""

      local ADB=""
      # WSL2: prefer adb in PATH (installed via: sudo apt-get install adb)
      # Fall back to Windows adb.exe via WSL interop
      if command -v adb &>/dev/null; then
        ADB="$(command -v adb)"
      elif [[ -f "/mnt/c/Users/alist/AppData/Local/Android/Sdk/platform-tools/adb.exe" ]]; then
        ADB="/mnt/c/Users/alist/AppData/Local/Android/Sdk/platform-tools/adb.exe"
      else
        echo "[ABORT] adb not found."
        echo "        Install on WSL2: sudo apt-get install -y adb"
        echo "        Or via Ansible: wsl -d Debian -- bash -l -c 'HAL provision wsl2 --tags phantom'"
        return 1
      fi
      echo "  adb: $ADB"
      echo ""

      local -a entries=("Tablet1:tablet1.local:$p1" "Tablet2:tablet2.local:$p2" "Tablet3:tablet3.local:$p3")
      for entry in "${entries[@]}"; do
        local name="${entry%%:*}" rest="${entry#*:}" host="${rest%%:*}" port="${rest#*:}"
        echo "--- $name ($host:$port) ---"
        local connect_out
        connect_out=$("$ADB" connect "$host:$port" 2>&1)
        if echo "$connect_out" | grep -qE 'connected|already connected'; then
          echo "  [ok] $connect_out"
        else
          echo "  [WARN] connect failed: $connect_out"
          echo "         → pair first: adb pair $host:<pair-port>  (6-digit code in Wireless Debugging)"
          echo "           then retry: HAL tablets fix-phantom with correct port"
          continue
        fi
        "$ADB" -s "$host:$port" shell settings put global settings_enable_monitor_phantom_procs 0 \
          && echo "  [ok] settings_enable_monitor_phantom_procs=0" \
          || echo "  [FAIL] write failed — ensure device is authorized (check: adb devices)"
        "$ADB" -s "$host:$port" shell settings put global max_phantom_processes 2147483647 \
          && echo "  [ok] max_phantom_processes=2147483647" \
          || echo "  [FAIL] write failed"
        local check
        check=$("$ADB" -s "$host:$port" shell settings get global settings_enable_monitor_phantom_procs 2>&1)
        echo "  verify: settings_enable_monitor_phantom_procs=$check (want: 0)"
        echo ""
      done
      ;;

    help|*)
      cat <<'TUSAGE'
HAL tablets <subcommand>

  Every subcommand prints current state (ssh/sshd/X11/xfce/barrier) first.

  check          Show state (alias: status)
  battery        Send battery-optimization exemption dialog to all tablets
                 (tap Allow × 2 per tablet, then run 'start')
  boot-install   Install termux-services, enable runit sshd, write Termux:Boot script
                 (one-time setup — sshd then auto-restarts on crash and Android boot)
                 Requires: Termux:Boot APK installed (F-Droid or GitHub sideload)
  sshd           Restart sshd on all tablets + post-check
  barrier-server Start Barrier service if not running (Windows service, auto on boot)
                 One-time setup already done on Laptop-P14s. UAC prompt on first call.
  start [N]      Start X11+XFCE4+Barrier on all tablets (or just 1/2/3)
                 Aborts if any tablet unreachable; post-check after
  stop           Stop X11+XFCE4+Barrier services on all tablets
  fix-phantom [p1 p2 p3]
                 Disable Android 12+ Phantom Process Killer via ADB.
                 Ports optional (default: 5555). Pass port shown in:
                   Developer Options → Wireless Debugging → "IP address & Port"
                 Prerequisites (one-time per tablet):
                   HAL tablets pair <pp1> <pp2> <pp3>
  pair <pp1> <pp2> <pp3>
                 One-time ADB Wireless pairing for all 3 tablets.
                 pp1/pp2/pp3 = pairing ports (Wireless Debugging → "Pair device with code")
                 Runs adb pair interactively — enter 6-digit code when prompted.
  help           This help
TUSAGE
      ;;
  esac
}

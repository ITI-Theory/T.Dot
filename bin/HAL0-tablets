#!/usr/bin/env bash
# HAL0-tablets — T-lane tablet implementation module
# Called via HAL0 dispatch. Never invoke directly.
# HAL1-tablets (if it ever exists) should source this first, then override.
# Contract (pre/post) is enforced by do_tablets() below.
#
# Defines: T1 T2 T3 SSH_OPTS
#          pack_tablets        — AI context pack (used by HAL prime tablets)
#          _tablet_check       — state check, returns 0 if ALL up
#          _do_start_one       — start X11+XFCE4+Barrier on one tablet
#          do_tablets          — dispatcher: check/battery/start/sshd/status/help

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

T1="u0_a304@10.133.134.207"
T2="u0_a360@10.133.134.219"
T3="u0_a297@10.133.134.110"
SSH_OPTS="-p 8022 -o ConnectTimeout=6 -o BatchMode=yes"

# ---------------------------------------------------------------------------
# Notes pack (used by: HAL prime tablets)
# ---------------------------------------------------------------------------

pack_tablets() {
  section "PACK: tablets — Tablet bootstrap & Xpra reference"
  cat <<'TABLETS'
## Tablet Setup Reference (3× Lenovo IdeaPad, Android/Termux)

### IPs and users
  Tablet 1:  u0_a304 @ 10.133.134.207  port 8022
  Tablet 2:  u0_a360 @ 10.133.134.219  port 8022
  Tablet 3:  u0_a297 @ 10.133.134.110  port 8022

### Bootstrap sequence — do this in order

  Step 1 (on each tablet, manually):
    pkg install openssh && sshd
    whoami          # note your u0_aNNN username
    ifconfig wlan0  # confirm IP

  Step 2 (from P14s — once per tablet):
    ssh-keygen -t ed25519 -N "" -f ~/.ssh/id_ed25519   # if not already done
    ssh-copy-id -p 8022 u0_a304@10.133.134.207
    ssh-copy-id -p 8022 u0_a360@10.133.134.219
    ssh-copy-id -p 8022 u0_a297@10.133.134.110

  Step 3 (from P14s — automation):
    ansible-playbook T.Dot/provisioning/tablets/site.yml
    # Installs: proot-distro, Debian bookworm, XFCE4, Barrier, dotfiles

  Step 4 (Barrier — Windows side):
    Barrier GUI → Configure Server → add Tablet1/Tablet2/Tablet3 in grid
    Screen name on each client must match exactly (capital T)
    SSL must be disabled: uncheck "Enable SSL" in GUI + --disable-crypto on client

### proot-distro
  Container name: debian  (Debian bookworm)
  Login: proot-distro login debian --bind ~/:/termux-home --bind $T/.X11-unix:/tmp/.X11-unix --
  Uses --kill-on-exit — wrap everything in tmux or it dies on SSH disconnect
  tmux socket (fixed path): /data/data/com.termux/files/usr/tmp/tmux.sock

### Termux:X11
  Android APK — sideload from https://github.com/termux/termux-x11/releases
  Launch: /system/bin/am start -n com.termux.x11/.MainActivity then TMPDIR=$T termux-x11 :0 &
  Socket: /data/data/com.termux/files/usr/tmp/.X11-unix/X0
  xkbcomp warnings: harmless, ignore them

### XFCE4
  Start inside proot: DISPLAY=:0 dbus-run-session -- xfce4-session
  (NOT dbus-launch — not present in bookworm dbus package)

### Barrier
  Version: 2.4.0 | Server: 10.133.134.136:24800
  SSL disabled — --disable-crypto on client + unchecked in GUI
  Screen names: Tablet1, Tablet2, Tablet3 (capital T)
  Client cmd: DISPLAY=:0 barrierc --no-tray --disable-crypto --name $NAME --display :0 10.133.134.136

### Battery optimization (CRITICAL)
  Android kills Termux when screen turns off unless exempted.
  Run: HAL tablets battery  → tap Allow × 2 on each tablet
  Verify exemption: dumpsys deviceidle whitelist | grep termux

### Tablet roles (soma-field instrument)
  Tablet 1:  OSC monitor / field state display
  Tablet 2:  Extended Stream Deck surface (Bitfocus Companion remote panel)
  Tablet 3:  TouchDesigner preview / fractal output mirror

TABLETS
}

# ---------------------------------------------------------------------------
# Internal: state check
# ---------------------------------------------------------------------------

_tablet_check() {
  # Prints one status line per tablet to stdout.
  # Returns 0 only if ALL three are reachable over SSH.
  local all_ok=0
  for pair in "Tablet1:$T1" "Tablet2:$T2" "Tablet3:$T3"; do
    local label="${pair%%:*}" host="${pair#*:}"
    local result
    result=$(ssh $SSH_OPTS "$host" \
      'SOCK=/data/data/com.termux/files/usr/tmp/tmux.sock
       sshd_n=$(pgrep -c sshd 2>/dev/null || echo 0)
       tmux_n=$(tmux -S "$SOCK" list-sessions 2>/dev/null | wc -l | tr -d " ")
       x11=$( [[ -e /data/data/com.termux/files/usr/tmp/.X11-unix/X0 ]] && echo yes || echo no )
       sessions=$(tmux -S "$SOCK" list-sessions 2>/dev/null || true)
       xfce=$(echo "$sessions" | grep -c xfce || true)
       barrier_sess=$(echo "$sessions" | grep -c barrier || true)
       barrierc_n=$(pgrep -c barrierc 2>/dev/null || echo 0)
       boot=$( [[ -x ~/.termux/boot/start-services.sh ]] && echo yes || echo "NO-run:boot-install" )
       echo "ssh=up sshd=$sshd_n tmux=$tmux_n X11=$x11 xfce=$xfce barrier_sess=$barrier_sess barrierc=$barrierc_n boot=$boot"' \
      2>/dev/null) || { echo "  $label ($host): SSH=DOWN"; all_ok=1; continue; }
    echo "  $label ($host): $result"
  done
  return $all_ok
}

# ---------------------------------------------------------------------------
# Internal: start one tablet
# ---------------------------------------------------------------------------

_do_start_one() {
  local host="$1" name="$2"
  echo "--- $name ($host) ---"
  ssh $SSH_OPTS "$host" bash <<ENDSSH
T=/data/data/com.termux/files/usr/tmp
SOCK=\$T/tmux.sock
NAME=$name
BARRIER=10.133.134.136

echo "[start] \$NAME — \$(date)"
# Acquire wakelock + ensure runsvdir (sshd supervisor) is running persistently.
# Both must outlive this SSH session, so disown them.
termux-wake-lock && echo "[ok] wakelock" || echo "[warn] wakelock failed (not fatal)"
SVDIR=/data/data/com.termux/files/usr/var/service
if ! pgrep -x runsvdir > /dev/null 2>&1; then
  nohup bash -c "runsvdir \$SVDIR" > /dev/null 2>&1 &
  disown
  sleep 1
  echo "[ok] runsvdir started"
else
  echo "[ok] runsvdir already running"
fi
# Only kill xfce/barrier sessions — leave termux-x11 alone if X socket already exists.
# Killing termux-x11 triggers "Process completed (press Enter)" in the Termux terminal,
# which blocks the next SSH connection until someone physically taps Enter on the tablet.
pkill -f xfce4-session 2>/dev/null; pkill -f barrierc 2>/dev/null
tmux -S "\$SOCK" kill-server 2>/dev/null
sleep 1
# Detect live vs stale X11 socket: check both the socket file and the server process.
x11_live=false
if [[ -S "\$T/.X11-unix/X0" ]] && pgrep -f "termux-x11" > /dev/null 2>&1; then
  x11_live=true
fi
if \$x11_live; then
  echo "[ok] X11 socket already up — skipping termux-x11 restart"
else
  echo "[info] X11 socket missing or stale — restarting termux-x11"
  pkill -f termux-x11 2>/dev/null
  rm -f "\$T/.X11-unix/X0"
  sleep 1
  /system/bin/am start -n com.termux.x11/.MainActivity > /dev/null 2>&1 &
  disown
  sleep 1
  TMPDIR=\$T termux-x11 :0 &
  disown
  sleep 4
fi
if [[ -S "\$T/.X11-unix/X0" ]]; then
  echo "[ok] X11 socket"
else
  echo "[error] X11 socket missing — open Termux:X11 APK on the tablet screen"
  exit 1
fi
tmux -S "\$SOCK" new-session -d -s xfce \
  "TMPDIR=\$T proot-distro login debian --bind ~/:/termux-home --bind \$T/.X11-unix:/tmp/.X11-unix -- bash -c 'DISPLAY=:0 dbus-run-session -- xfce4-session'"
sleep 4
echo "[ok] xfce tmux session"
tmux -S "\$SOCK" new-session -d -s barrier \
  "TMPDIR=\$T proot-distro login debian --bind ~/:/termux-home --bind \$T/.X11-unix:/tmp/.X11-unix -- bash -c 'while true; do DISPLAY=:0 barrierc --no-tray --disable-crypto --name \$NAME --display :0 \$BARRIER; sleep 3; done'"
sleep 4
barrierc_n=\$(pgrep -c barrierc 2>/dev/null || echo 0)
if [[ "\$barrierc_n" -gt 0 ]]; then
  echo "[ok] barrierc running (pid count=\$barrierc_n)"
else
  echo "[WARN] barrierc NOT running — barrier server may be down or screen name wrong (\$NAME)"
  echo "       Check: is Barrier server running on \$BARRIER with screen '\$NAME' configured?"
fi
tmux -S "\$SOCK" list-sessions
echo "[done] \$NAME"
ENDSSH
}

# ---------------------------------------------------------------------------
# Internal: start (or restart) the Barrier server in WSL2 tmux
# ---------------------------------------------------------------------------

_do_start_barrier_server() {
  # Manages the Windows Barrier service (barrierd.exe), which owns barriers.exe.
  # One-time setup (already done on Laptop-P14s):
  #   sc.exe config Barrier start= auto          (requires elevation)
  #   reg add HKCU\Software\Debauchee\Barrier /v configFile /d <path> /f
  #   reg add HKCU\Software\Debauchee\Barrier /v autoConfig /d false /f
  #   reg add HKCU\Software\Debauchee\Barrier /v autoStart  /d true  /f
  # After that, just: sc start/stop Barrier (via UAC elevation below).

  local state
  state=$(sc.exe query Barrier 2>/dev/null | grep 'STATE' | awk '{print $4}')

  if [[ "$state" == "RUNNING" ]]; then
    echo "[ok] Barrier service already RUNNING"
    netstat.exe -anop tcp 2>/dev/null | grep ':24800' || true
    return 0
  fi

  echo "[info] Starting Barrier service (requires UAC)..."
  powershell.exe -NoProfile -Command \
    "Start-Process powershell -Verb RunAs -Wait -ArgumentList '-NoProfile -Command sc.exe start Barrier'" \
    2>/dev/null
  sleep 3

  if netstat.exe -anop tcp 2>/dev/null | grep -q ':24800'; then
    echo "[ok] Barrier service started — port 24800 listening"
    tasklist.exe 2>/dev/null | grep -i 'barriers\|barrierd' || true
  else
    echo "[WARN] Barrier service did not start — port 24800 not listening"
    sc.exe query Barrier 2>/dev/null | grep 'STATE' || true
  fi
}

# ---------------------------------------------------------------------------
# do_tablets — public dispatcher (contract: pre → impl → post)
# ---------------------------------------------------------------------------

do_tablets() {
  local sub="${1:-help}"
  shift || true

  # Always show current state before doing anything (except help)
  local pre_ok=0
  if [[ "$sub" != "help" ]]; then
    echo "=== State ==="
    _tablet_check || pre_ok=$?
    echo ""
  fi

  case "$sub" in

    check|status)
      # State already printed above — nothing more to do
      ;;

    battery)
      # {P: tablets reachable} send dialog {Q: dialog shown on tablet screen}
      echo "=== Sending battery-optimization exemption dialogs ==="
      echo "(Tap 'Allow' × 2 on each tablet screen when dialogs appear)"
      for pair in "Tablet1:$T1" "Tablet2:$T2" "Tablet3:$T3"; do
        local label="${pair%%:*}" host="${pair#*:}"
        printf "  %s: " "$label"
        ssh $SSH_OPTS "$host" \
          '/system/bin/am start -a android.settings.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS -d "package:com.termux" && sleep 1 && /system/bin/am start -a android.settings.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS -d "package:com.termux.x11"' \
          && echo "[ok] dialogs launched — TAP ALLOW on tablet" \
          || echo "[FAILED] SSH connect failed"
      done
      echo ""
      echo "After tapping Allow × 2 per tablet, run: HAL tablets start"
      ;;

    barrier-server)
      # {P: running in WSL2} start barriers.exe in WSL2 tmux session {Q: port 24800 listening}
      echo "=== Starting Barrier server (WSL2-owned) ==="
      _do_start_barrier_server
      ;;

    start)
      # {P: all tablets ssh=up} start X11+XFCE4+Barrier {Q: xfce=1 barrier=1 per tablet}
      if [[ $pre_ok -ne 0 ]]; then
        echo "[ABORT] One or more tablets unreachable — cannot start."
        echo "        Open Termux on each tablet and run: sshd"
        return 1
      fi
      local name="${1:-}"
      if [[ -n "$name" ]]; then
        case "$name" in
          1|Tablet1) _do_start_one "$T1" Tablet1 ;;
          2|Tablet2) _do_start_one "$T2" Tablet2 ;;
          3|Tablet3) _do_start_one "$T3" Tablet3 ;;
          *) echo "[HAL] Unknown tablet: $name (use 1/2/3 or Tablet1/Tablet2/Tablet3)"; return 1 ;;
        esac
      else
        echo "=== Starting desktops on all 3 tablets in parallel ==="
        _do_start_one "$T1" Tablet1 &
        _do_start_one "$T2" Tablet2 &
        _do_start_one "$T3" Tablet3 &
        wait
      fi
      echo ""
      echo "=== Post-check ==="
      _tablet_check
      ;;

    sshd)
      # {P: Termux process alive} restart sshd {Q: sshd running}
      echo "=== Restarting sshd on all tablets ==="
      for pair in "Tablet1:$T1" "Tablet2:$T2" "Tablet3:$T3"; do
        local label="${pair%%:*}" host="${pair#*:}"
        printf "  %s: " "$label"
        ssh $SSH_OPTS "$host" 'pkill sshd 2>/dev/null; sleep 1; sshd && echo "[ok]"' \
          || echo "[FAILED] connect failed"
      done
      echo ""
      echo "=== Post-check ==="
      _tablet_check
      ;;

    boot-install)
      # {P: tablets reachable} install termux-services + runit sshd + Termux:Boot script
      # {Q: sshd supervised by runit; ~/.termux/boot/start-services.sh in place}
      echo "=== Installing termux-services + runit sshd on all tablets ==="
      echo ""
      for pair in "Tablet1:$T1" "Tablet2:$T2" "Tablet3:$T3"; do
        local label="${pair%%:*}" host="${pair#*:}"
        echo "--- $label ($host) ---"
        ssh $SSH_OPTS "$host" 'bash -s' <<'BOOTSCRIPT' || { echo "  [ABORT] $label — see above"; continue; }
# Pre-check: Termux:Boot APK must be installed for ~/.termux/boot/ to fire
if pm list packages 2>/dev/null | grep -q 'com.termux.boot'; then
  echo "[ok] Termux:Boot APK installed"
else
  echo "[ABORT] Termux:Boot APK NOT installed on this device"
  echo "        Install from: https://f-droid.org/packages/com.termux.boot/"
  echo "        or: https://github.com/termux/termux-boot/releases"
  echo "        Then re-run: HAL tablets boot-install"
  exit 1
fi
# Fix any half-configured packages before installing (avoids interactive conffile prompts)
DEBIAN_FRONTEND=noninteractive dpkg --configure -a --force-confold 2>/dev/null || true
DEBIAN_FRONTEND=noninteractive apt-get install -y -o Dpkg::Options::="--force-confold" termux-services
sv-enable sshd
sv up sshd 2>/dev/null || true
mkdir -p ~/.termux/boot
cat > ~/.termux/boot/start-services.sh << 'BOOTEOF'
#!/data/data/com.termux/files/usr/bin/sh
termux-wake-lock
. $PREFIX/etc/profile
BOOTEOF
chmod +x ~/.termux/boot/start-services.sh
echo "[ok] termux-services installed, sshd enabled under runit"
echo "[ok] boot script: ~/.termux/boot/start-services.sh"
sv status sshd 2>&1 || echo "(runit not running yet — active after next reboot)"
BOOTSCRIPT
        echo ""
      done
      echo "=== Post-check ==="
      _tablet_check
      ;;

    help|*)
      cat <<'TUSAGE'
HAL tablets <subcommand>

  Every subcommand prints current state (ssh/sshd/X11/xfce/barrier) first.

  check          Show state (alias: status)
  battery        Send battery-optimization exemption dialog to all tablets
                 (tap Allow × 2 per tablet, then run 'start')
  boot-install   Install termux-services, enable runit sshd, write Termux:Boot script
                 (one-time setup — sshd then auto-restarts on crash and Android boot)
                 Requires: Termux:Boot APK installed (F-Droid or GitHub sideload)
  sshd           Restart sshd on all tablets + post-check
  barrier-server Start Barrier service if not running (Windows service, auto on boot)
                 One-time setup already done on Laptop-P14s. UAC prompt on first call.
  start [N]      Start X11+XFCE4+Barrier on all tablets (or just 1/2/3)
                 Aborts if any tablet unreachable; post-check after
  help           This help
TUSAGE
      ;;
  esac
}

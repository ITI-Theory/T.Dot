#!/usr/bin/env bash
# HAL dispatcher — routes to the highest installed layer.
# T.Dot/bin/HAL0 init links both HAL0 and this dispatcher into ~/.local/bin.
# Each lane adds its own HALn: U.Dot links HAL1, T.Live will link HAL2, etc.
# The highest present layer handles the command (and forwards downward as needed).
set -euo pipefail

for hal in HAL2 HAL1 HAL0; do
  cmd="$HOME/.local/bin/$hal"
  [[ -x "$cmd" ]] && exec "$cmd" "$@"
done

echo "HAL: no layer installed (expected HAL0 in ~/.local/bin)" >&2
exit 1
